# 環境変数（APIキー等）
.env
.env.*
!.env.example

# 依存
node_modules/

# 実行時データ（SQLite・WAL/SHM 含む）
data/
*.db
*.db-shm
*.db-wal

# ログ
*.log

# OS / エディタ
.DS_Store
*.swp
.idea/
.vscode/

# 一時ファイル
*.tmp
tmp/

# TypeScript 増分ビルドキャッシュ（マシン依存の生成物）
*.tsbuildinfo

# Playwright MCP の生成物
.playwright-mcp/

# スケジュールタスクのロックファイル（実行時生成物）
.claude/scheduled_tasks.lock
